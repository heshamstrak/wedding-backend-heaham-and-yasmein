# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/wedding"

# Admin password — used to protect /admin and /wedding/stats
ADMIN_PASSWORD="your-secret-password-here"

# Port the server listens on (default: 3000)
PORT=3000

# Allowed CORS origins (comma-separated)
# Add your GitHub Pages URL here, e.g. https://heshamstrak.github.io
CORS_ORIGIN="https://heshamstrak.github.io,http://localhost:5500"
